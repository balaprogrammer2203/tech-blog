NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5175
ADMIN_ORIGIN=http://localhost:5174

# Local: default DB name techblog (create automatically on first write)
MONGODB_URI=mongodb://127.0.0.1:27017/techblog
# Atlas (production): mongodb+srv://USER:PASS@CLUSTER.mongodb.net/techblog?retryWrites=true&w=majority

JWT_ACCESS_SECRET=change-me-access-min-32-chars-long-secret
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-different
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Small pool is fine for Atlas M0 or local single-node MongoDB
MONGODB_MAX_POOL_SIZE=5
